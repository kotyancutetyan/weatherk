<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetAvatarRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000000"
    android:gravity="top|center_horizontal"
    android:orientation="vertical"
    android:padding="4dp">

    <TextView
        android:id="@+id/widgetAvatarCity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:text="Москва"
        android:textColor="#E6FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widgetAvatarWeather"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:text="🌤️ · 12°C"
        android:textColor="#D0FFFFFF"
        android:textSize="10sp"
        android:layout_marginBottom="4dp" />

    <ImageView
        android:id="@+id/widgetAvatarImage"
        android:layout_width="74dp"
        android:layout_height="112dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/widget_avatar_name"
        android:scaleType="fitCenter"
        android:layout_gravity="center_horizontal" />

    <TextView
        android:id="@+id/widgetAvatarText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:text="Катюша, ты прекрасная!"
        android:textColor="#CCFFFFFF"
        android:textSize="9sp"
        android:layout_marginTop="2dp" />

</LinearLayout>

